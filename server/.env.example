# Copy this file to server/.env and fill in your Supabase project values
# (Supabase Dashboard → Project Settings → API).

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

PORT=4000

# The frontend's dev server URL, so CORS allows it to call this API.
CORS_ORIGIN=http://localhost:5173

# Optional. Used by customer/staff password reset emails.
# For local development, add http://localhost:5173/reset-password to the
# Supabase Authentication redirect URL allow-list.
PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/reset-password
